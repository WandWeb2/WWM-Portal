# =============================================================================
# WandWeb Portal 2.0 - Environment Configuration
# =============================================================================
# This file documents all environment variables needed for the Portal.
# For PHP configuration, see private/secrets.php.example
# DO NOT commit actual secrets to version control!

# Database Configuration
# ----------------------
# For MySQL/MariaDB:
DB_HOST=localhost
DB_NAME=wandweb_portal
DB_USER=your_database_user
DB_PASS=your_database_password

# For SQLite (local development):
# DB_DSN=sqlite:/path/to/data/portal.sqlite

# JWT Secret (generate with: openssl rand -base64 32)
# ----------------------
JWT_SECRET=your_jwt_secret_key_min_32_chars_random_string

# Google OAuth & Drive Integration
# ----------------------
# See GOOGLE_DRIVE_SETUP.md for setup instructions
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=1//0xxx-your-refresh-token

# Stripe Billing Integration
# ----------------------
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx_or_sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Gemini AI Integration
# ----------------------
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# SwipeOne Analytics (Optional)
# ----------------------
SWIPEONE_API_KEY=your_swipeone_api_key

# SMTP/Email Configuration
# ----------------------
# For sending notifications and password resets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=WandWeb Portal

# Application Settings
# ----------------------
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com

# File Upload Settings
# ----------------------
# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE=100
# Storage method: 'drive' or 'local'
STORAGE_METHOD=drive
# Local storage path (if using local storage)
UPLOAD_PATH=/var/www/portal/uploads

# Security Settings
# ----------------------
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Session timeout (in seconds)
SESSION_TIMEOUT=3600

# Logging
# ----------------------
# Log level: debug, info, warning, error
LOG_LEVEL=error
# Log to file: true or false
LOG_TO_FILE=true
LOG_FILE_PATH=/var/www/portal/logs/portal.log
