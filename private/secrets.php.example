 */

return [
    // Database Configuration
    // ----------------------
    // For MySQL/MariaDB (recommended for production):
    'DB_HOST' => 'localhost',
    'DB_NAME' => 'wandweb_portal',
    'DB_USER' => 'your_database_user',
    'DB_PASS' => 'your_database_password',
    
    // Alternative: SQLite for local development
    // Uncomment the line below and comment out MySQL settings above:
    // 'DB_DSN' => 'sqlite:' . __DIR__ . '/../data/portal.sqlite',
    
    // JWT Authentication
    // ----------------------
    // Generate with: openssl rand -base64 32
    'JWT_SECRET' => 'your_jwt_secret_key_min_32_chars_random_string_here',
    
    // Google OAuth & Drive Integration
    // ----------------------
    // See GOOGLE_DRIVE_SETUP.md for detailed setup instructions
    'GOOGLE_CLIENT_ID' => getenv('GOOGLE_CLIENT_ID') ?: 'your-client-id.apps.googleusercontent.com',
    'GOOGLE_CLIENT_SECRET' => getenv('GOOGLE_CLIENT_SECRET') ?: 'your-google-client-secret',
    'GOOGLE_REFRESH_TOKEN' => getenv('GOOGLE_REFRESH_TOKEN') ?: '1//0xxx-your-refresh-token',
    
    // Stripe Billing Integration
    // ----------------------
    // Get your API keys from: https://dashboard.stripe.com/apikeys
    // Use test keys (sk_test_) for development, live keys (sk_live_) for production
    'STRIPE_SECRET_KEY' => getenv('STRIPE_SECRET_KEY') ?: 'sk_test_xxx_your_stripe_secret_key',
    'STRIPE_WEBHOOK_SECRET' => getenv('STRIPE_WEBHOOK_SECRET') ?: 'whsec_xxx_your_webhook_secret',
    
    // Gemini AI Integration
    // ----------------------
    // Get your API key from: https://makersuite.google.com/app/apikey
    'GEMINI_API_KEY' => getenv('GEMINI_API_KEY') ?: 'your_gemini_api_key_here',
    
    // SwipeOne Analytics (Optional)
    // ----------------------
    'SWIPEONE_API_KEY' => getenv('SWIPEONE_API_KEY') ?: '',
    
    // SMTP/Email Configuration (Optional but recommended)
    // ----------------------
    'SMTP_HOST' => getenv('SMTP_HOST') ?: 'smtp.gmail.com',
    'SMTP_PORT' => getenv('SMTP_PORT') ?: 587,
    'SMTP_USER' => getenv('SMTP_USER') ?: 'your_email@gmail.com',
    'SMTP_PASS' => getenv('SMTP_PASS') ?: 'your_app_password',
    'SMTP_FROM' => getenv('SMTP_FROM') ?: 'noreply@yourdomain.com',
    'SMTP_FROM_NAME' => getenv('SMTP_FROM_NAME') ?: 'WandWeb Portal',
    
    // Application Settings
    // ----------------------
    'APP_ENV' => getenv('APP_ENV') ?: 'production',
    'APP_DEBUG' => getenv('APP_DEBUG') ?: 'false',
    'APP_URL' => getenv('APP_URL') ?: 'https://yourdomain.com',
    
    // File Upload Settings
    // ----------------------
    'MAX_UPLOAD_SIZE' => getenv('MAX_UPLOAD_SIZE') ?: 100, // in MB
    'STORAGE_METHOD' => getenv('STORAGE_METHOD') ?: 'drive', // 'drive' or 'local'
    'UPLOAD_PATH' => getenv('UPLOAD_PATH') ?: __DIR__ . '/../uploads',
    
    // Security Settings
    // ----------------------
    // CRITICAL: Change '*' to your domain in production (e.g., 'https://yourdomain.com')
    'CORS_ORIGINS' => getenv('CORS_ORIGINS') ?: 'https://yourdomain.com',
    'SESSION_TIMEOUT' => getenv('SESSION_TIMEOUT') ?: 3600, // in seconds
    
    // Logging
    // ----------------------
    'LOG_LEVEL' => getenv('LOG_LEVEL') ?: 'error', // debug, info, warning, error
    'LOG_TO_FILE' => getenv('LOG_TO_FILE') ?: 'true',
    'LOG_FILE_PATH' => getenv('LOG_FILE_PATH') ?: __DIR__ . '/../logs/portal.log',
];
